{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/home/mubarkahimself/Desktop/QUANTMINDX"],
      "description": "File system access for EA code, strategies, and workspaces"
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      },
      "description": "GitHub integration for EA sync and version control"
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      },
      "description": "MQL5 documentation lookup"
    },
    "mt5-compiler": {
      "name": "MT5 Compiler",
      "url": "local://mt5-compiler",
      "type": "mt5_compiler",
      "enabled": true,
      "description": "MQL5 code compilation (requires MT5 installation)",
      "tools": ["compile_mql5_code", "validate_mql5_syntax", "get_compilation_errors"],
      "config": {
        "mt5_path": "/MT5",
        "output_dir": "/MT5/MQL5/Experts",
        "timeout": 60
      }
    },
    "backtest-server": {
      "name": "Backtest MCP",
      "url": "http://localhost:8081",
      "type": "backtest",
      "enabled": true,
      "description": "Strategy backtesting engine",
      "tools": ["run_backtest", "get_backtest_status", "get_backtest_results"],
      "config": {
        "max_concurrent": 3,
        "timeout": 300
      }
    }
  },
  "defaultServer": "filesystem",
  "fallbackOrder": ["filesystem", "github", "context7"],
  "healthCheck": {
    "interval": 60,
    "timeout": 10,
    "retryAttempts": 3
  }
}
