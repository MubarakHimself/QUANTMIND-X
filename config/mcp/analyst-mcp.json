{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/home/mubarkahimself/Desktop/QUANTMINDX"],
      "description": "File system access for NPRD/TRD files and workspaces"
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      },
      "description": "GitHub integration for strategy research"
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp",
      "description": "Documentation and research lookup"
    },
    "brave-search": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-brave-search"],
      "env": {
        "BRAVE_API_KEY": "${BRAVE_API_KEY}"
      },
      "description": "Web search for market research"
    },
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "description": "Persistent memory for research findings"
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"],
      "description": "Task decomposition and reasoning"
    },
    "pageindex-articles": {
      "name": "PageIndex Articles",
      "url": "http://localhost:3000",
      "type": "pageindex",
      "enabled": true,
      "description": "Search indexed trading articles",
      "tools": ["search_articles", "get_article"]
    },
    "backtest-server": {
      "name": "Backtest Server",
      "url": "http://localhost:8081",
      "type": "backtest",
      "enabled": true,
      "description": "Strategy backtesting",
      "tools": ["run_backtest", "get_backtest_status", "get_backtest_results"]
    },
    "obsidian": {
      "command": "npx",
      "args": ["-y", "@smithery/mcp-obsidian"],
      "env": {
        "OBSIDIAN_VAULT_PATH": "/home/mubarkahimself/vault"
      },
      "description": "Obsidian vault for research notes and knowledge"
    }
  },
  "defaultServer": "filesystem",
  "fallbackOrder": ["filesystem", "github", "context7", "brave-search", "memory", "sequential-thinking", "obsidian"],
  "healthCheck": {
    "interval": 60,
    "timeout": 10,
    "retryAttempts": 3
  }
}
