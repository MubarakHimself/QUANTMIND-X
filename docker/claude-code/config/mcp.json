{
  "context7": {
    "type": "http",
    "url": "https://mcp.context7.com/mcp",
    "headers": {
      "CONTEXT7_API_KEY": "YOUR_API_KEY"
    }
  },
  "MCP_DOCKER": {
    "command": "docker",
    "args": [
      "mcp",
      "gateway",
      "run"
    ]
  },
  "svelte": {
    "command": "npx",
    "args": [
      "-y",
      "@sveltejs/mcp"
    ],
    "type": "stdio"
  },
  "chrome_devtools": {
    "command": "npx",
    "args": [
      "chrome-devtools-mcp@latest"
    ]
  }
}
