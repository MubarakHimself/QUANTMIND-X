{
  "mcpServers": {
    "context7": {
      "name": "Context7",
      "url": "https://context7.com/websites/mql5_en",
      "type": "context7",
      "enabled": true,
      "description": "MQL5 documentation retrieval",
      "tools": [
        "get_mql5_documentation",
        "get_mql5_examples"
      ],
      "config": {
        "cache_ttl": 3600,
        "max_results": 10,
        "timeout": 30
      }
    },
    "sequential_thinking": {
      "name": "Sequential Thinking",
      "url": "local://sequential-thinking",
      "type": "sequential_thinking",
      "enabled": true,
      "description": "Task decomposition and step-by-step reasoning",
      "tools": [
        "sequential_thinking",
        "analyze_errors"
      ],
      "config": {
        "max_steps": 15,
        "timeout": 60
      }
    },
    "pageindex": {
      "name": "PageIndex",
      "url": "http://localhost:8080",
      "type": "pageindex",
      "enabled": true,
      "description": "PDF indexing and search",
      "tools": [
        "index_pdf",
        "search_pdf",
        "get_indexed_documents"
      ],
      "config": {
        "namespaces": {
          "mql5_book": {
            "description": "MQL5 Programming Book",
            "pdf_path": "/home/mubarkahimself/Desktop/QUANTMINDX/mql5book.pdf"
          },
          "strategies": {
            "description": "Trading strategies documentation"
          },
          "knowledge": {
            "description": "General knowledge base"
          }
        },
        "timeout": 120
      }
    },
    "backtest": {
      "name": "Backtest MCP",
      "url": "http://localhost:8081",
      "type": "backtest",
      "enabled": true,
      "description": "Strategy backtesting engine",
      "tools": [
        "run_backtest",
        "get_backtest_status",
        "get_backtest_results",
        "compare_backtests"
      ],
      "config": {
        "max_concurrent": 3,
        "default_config": {
          "symbol": "EURUSD",
          "timeframe": "H1",
          "initial_deposit": 10000
        },
        "timeout": 300
      }
    },
    "mt5_compiler": {
      "name": "MT5 Compiler",
      "url": "local://mt5-compiler",
      "type": "mt5_compiler",
      "enabled": true,
      "description": "MQL5 code compilation",
      "tools": [
        "compile_mql5_code",
        "validate_mql5_syntax",
        "get_compilation_errors"
      ],
      "config": {
        "mt5_path": "/MT5",
        "output_dir": "/MT5/MQL5/Experts",
        "timeout": 60
      }
    }
  },
  "defaultServer": "context7",
  "fallbackOrder": [
    "context7",
    "pageindex",
    "sequential_thinking"
  ],
  "healthCheck": {
    "interval": 60,
    "timeout": 10,
    "retryAttempts": 3
  }
}
