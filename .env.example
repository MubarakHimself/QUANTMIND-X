# ============================================
# Security Configuration (Required for Production)
# ============================================
# Application secret key - MUST be set for production deployments
# Generate a strong key: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here

# Firecrawl API Key
# Get your key from: https://www.firecrawl.dev/
FIRECRAWL_API_KEY=your_api_key_here

# PageIndex Configuration
# Knowledge retrieval services for articles, books, and logs
PAGEINDEX_ARTICLES_URL=http://localhost:3000
PAGEINDEX_BOOKS_URL=http://localhost:3001
PAGEINDEX_LOGS_URL=http://localhost:3002

# LLM API Keys (for categorization)
# OPENAI_API_KEY=your_openai_key
# ANTHROPIC_API_KEY=your_anthropic_key

# V8 Crypto Module - Binance API Configuration
# Get your keys from: https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# Binance Testnet Configuration (for testing)
# Get testnet keys from: https://testnet.binance.vision/
BINANCE_TESTNET_KEY=your_testnet_api_key_here
BINANCE_TESTNET_SECRET=your_testnet_api_secret_here

# Binance Futures (optional)
BINANCE_FUTURES_ENABLED=false

# MT5 Socket Connection
MT5_VPS_HOST=localhost
MT5_VPS_PORT=5555
MT5_ACCOUNT_ID=12345678

# Paper Trading
PAPER_TRADING_REDIS_HOST=localhost
PAPER_TRADING_REDIS_PORT=6379
PAPER_TRADING_REDIS_DB=0

# ============================================
# Grafana Cloud Monitoring (Production)
# ============================================
# Sign up at https://grafana.com/auth/sign-up/create-user
# Create a stack and get your endpoints from the Configuration page
# Generate an API key with MetricsPublisher role

# Prometheus remote write URL (for metrics)
GRAFANA_PROMETHEUS_URL=https://prometheus-prod-XX-prod-XX-XX.grafana.net

# Loki URL (for logs)
GRAFANA_LOKI_URL=https://logs-prod-XX.grafana.net

# Your Grafana Cloud instance/stack ID
GRAFANA_INSTANCE_ID=your_instance_id

# API key with MetricsPublisher role
GRAFANA_API_KEY=your_api_key

# Metrics server ports
PROMETHEUS_PORT=9090
MT5_PROMETHEUS_PORT=9091

# QuantMindX system config
QUANTMIND_ENV=development
QUANTMIND_VERSION=1.0.0

# CORS Configuration
# Comma-separated list of allowed origins for API requests
# Use "*" to allow all origins (not recommended for production with credentials)
CORS_ALLOWED_ORIGINS=tauri://localhost,tauri://127.0.0.1,http://localhost:1420,http://localhost:5173,http://localhost:3000,http://127.0.0.1:1420,http://127.0.0.1:5173,http://127.0.0.1:3000,https://app.quantmindx.com,https://www.quantmindx.com,https://quantmindx.com

# ============================================
# Multi-Tier Database Architecture
# ============================================

# Hot Tier (PostgreSQL) - Cloudzy
# Contains real-time tick_cache data for current price queries
HOT_DB_URL=postgresql://postgres:password@localhost:5432/quantmind_hot
CLOUDZY_HOT_DB_URL=postgresql://postgres:password@cloudzy-ip:5432/quantmind_hot

# Warm Tier (DuckDB) - Cloudzy
WARM_DB_PATH=/data/market_data.duckdb

# Cold Tier (Parquet) - Contabo
COLD_STORAGE_PATH=/data/cold_storage
CONTABO_COLD_STORAGE=root@155.133.27.86:/data/cold_storage

# ============================================
# Multi-VPS Synchronization
# ============================================

# Contabo VPS (set on Cloudzy VPS)
CONTABO_HOST=your_contabo_ip
CONTABO_USER=root
CONTABO_SSH_KEY_PATH=/root/.ssh/contabo_id_rsa
CONTABO_HMM_API_URL=http://your_contabo_ip:8001
CONTABO_HMM_API_KEY=your_cross_vps_api_key

# Cloudzy VPS (set on Contabo VPS)
CLOUDZY_HOST=your_cloudzy_ip

# Data Retention (days) - how long to keep data in WARM tier before archiving to COLD
RETENTION_DAYS=7

# ============================================
# Claude CLI Configuration (v2 Agent Stack)
# ============================================
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Claude memory service port (claude-mem web viewer)
CLAUDE_MEM_PORT=37777

# ============================================
# LLM Provider Configuration
# ============================================
# Primary LLM Provider (anthropic, zai, zhipu, minimax, openrouter)
LLM_PROVIDER=zai

# GLM/ZHIPU API Configuration (Zhipu AI - Chinese LLM provider)
# Get your key from: https://open.bigmodel.cn/
ZHIPU_API_KEY=your_zhipu_key_here

# Z.AI API Configuration (Anthropic-compatible GLM endpoint)
# Get your key from: https://www.z.ai/
ZAI_API_KEY=your_zai_key_here
ZAI_BASE_URL=https://api.z.ai/api/anthropic

# Minimax API Configuration (M2.5, M2.1, M2 models)
# Get your key from: https://platform.minimax.io/
MINIMAX_API_KEY=your_minimax_key_here

# OpenRouter API (alternative routing)
# Get your key from: https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_key_here

# GLM Thinking Mode Configuration
GLM_THINKING_TYPE=enabled
GLM_THINKING_MODE=interleaved
GLM_CLEAR_THINKING=false

# ============================================
# GitHub EA Sync (Cloudzy VPS)
# ============================================
# Synchronizes Expert Advisor files from GitHub repositories
# Used by src/integrations/github_ea_sync.py and github_ea_scheduler.py

# GitHub repository URL containing .mq5 EA files
# Example: https://github.com/username/ea-repository
GITHUB_EA_REPO_URL=

# Branch to sync from (default: main)
GITHUB_EA_BRANCH=main

# GitHub Personal Access Token for private repositories
# Create at: https://github.com/settings/tokens
# Required scopes: repo (for private repos), public_repo (for public repos)
GITHUB_ACCESS_TOKEN=

# Local path for cloned EA repository
# This directory will be created automatically if it doesn't exist
EA_LIBRARY_PATH=/data/ea-library

# Sync interval in hours (default: 24)
# The scheduler will pull updates and scan for new/modified EAs
GITHUB_EA_SYNC_INTERVAL_HOURS=24

# ============================================
# System Configuration
# ============================================
# NODE_ROLE: Controls which router groups register at startup
# Accepted values: contabo | cloudzy | local (default: local)
# - contabo: Agent/compute endpoints only
# - cloudzy: Live trading endpoints only
# - local: All endpoints (development mode)
NODE_ROLE=local

# ============================================
# MCP Server Configuration
# ============================================
# Path to MCP configuration file
MCP_CONFIG_PATH=./config/mcp.json

# ============================================
# Video Ingest Configuration (Optional)
# ============================================
# Qwen VL API Configuration
QWEN_API_KEY=your_qwen_api_key_here
QWEN_HEADLESS=true
QWEN_MODEL=Qwen2-VL-72B-Instruct

# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_YOLO_MODE=false

# Video Ingest Rate Limits
QWEN_REQUESTS_PER_DAY=100

# Video Ingest Cache Settings
VideoIngest_CACHE_DIR=/data/video_cache
VideoIngest_CACHE_MAX_SIZE_GB=10
VideoIngest_CACHE_MAX_AGE_DAYS=30
VideoIngest_MAX_CONCURRENT_JOBS=2
VideoIngest_JOB_DB_PATH=/data/video_jobs.db
VideoIngest_OUTPUT_DIR=/data/video_output
VideoIngest_FRAME_INTERVAL=5
VideoIngest_AUDIO_BITRATE=128k
VideoIngest_AUDIO_CHANNELS=1
VideoIngest_MAX_RETRY_ATTEMPTS=3
VideoIngest_BASE_RETRY_DELAY=5
VideoIngest_LOG_LEVEL=INFO
VideoIngest_LOG_FILE=/var/log/quantmind/video_ingest.log

# ============================================
# Tick Data Configuration
# ============================================
# Use demo ticks for live trading to prevent broker manipulation of live data
# When enabled, tick data is sourced from a separate demo connection
USE_DEMO_TICKS=false

# MT5 Demo Connection (for tick source when USE_DEMO_TICKS=true)
MT5_DEMO_LOGIN=
MT5_DEMO_PASSWORD=
MT5_DEMO_SERVER=